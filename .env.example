# ============================================
# GYDS Wallet — Self-Hosting Configuration
# ============================================
# Copy this file to .env and fill in your values.
# All variables prefixed with VITE_ are available
# in the browser at import.meta.env.VITE_*

# ── Network / RPC ────────────────────────────
# Primary RPC endpoint for the GYDS chain
VITE_RPC_URL=https://rpc.netlifegy.com

# Fallback RPC endpoints (comma-separated)
VITE_RPC_FALLBACKS=https://rpc2.netlifegy.com,https://rpc3.netlifegy.com

# Chain ID (decimal)
VITE_CHAIN_ID=13370

# Chain ID (hex, with 0x prefix)
VITE_CHAIN_ID_HEX=0x343A

# Native token symbol
VITE_NATIVE_SYMBOL=GYDS

# Network display name
VITE_NETWORK_NAME=GYDS Network

# Block explorer base URL
VITE_BLOCK_EXPLORER=https://explorer.netlifegy.com

# Network environment: mainnet, testnet, or devnet
# Controls which indexer endpoints are used for NFTs and data
VITE_NETWORK_ENV=mainnet

# ── Multi-Chain ──────────────────────────────
# Enable additional chains (comma-separated IDs)
# Supported: gyds, ethereum, polygon, solana
VITE_ENABLED_CHAINS=gyds

# GYDS WebSocket (live block & balance updates)
VITE_GYDS_WS_URL=wss://rpc.netlifegy.com

# Ethereum RPC endpoints (comma-separated, JSON-RPC / WebSocket)
VITE_ETH_RPC_URLS=https://eth.llamarpc.com,https://rpc.ankr.com/eth
VITE_ETH_WS_URL=wss://eth.llamarpc.com

# Polygon RPC endpoints
VITE_POLYGON_RPC_URLS=https://polygon-rpc.com,https://rpc.ankr.com/polygon
VITE_POLYGON_WS_URL=wss://polygon-bor-rpc.publicnode.com

# Solana RPC endpoints
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
VITE_SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# ── Indexer / NFT APIs ───────────────────────
# Alchemy API key (supports Ethereum, Polygon, Solana NFTs)
# Get one at https://www.alchemy.com/
VITE_ALCHEMY_API_KEY=

# Moralis API key (alternative NFT indexer)
# Get one at https://moralis.io/
VITE_MORALIS_API_KEY=

# ── Pricing ──────────────────────────────────
# CoinGecko API base URL (free tier works)
VITE_COINGECKO_API=https://api.coingecko.com/api/v3

# CoinGecko Pro API key (optional, for higher rate limits)
VITE_COINGECKO_API_KEY=

# Price refresh interval in milliseconds (default 60000 = 1 min)
VITE_PRICE_REFRESH_MS=60000

# ── Wallet ───────────────────────────────────
# Number of PBKDF2 iterations for wallet encryption (default 100000)
VITE_PBKDF2_ITERATIONS=100000

# Lockout attempts before 5-minute cooldown (default 5)
VITE_LOCKOUT_ATTEMPTS=5

# Lockout duration in seconds (default 300 = 5 min)
VITE_LOCKOUT_DURATION=300

# ── PWA / Branding ───────────────────────────
# App display name
VITE_APP_NAME=GYDS Wallet

# Short name (home screen label)
VITE_APP_SHORT_NAME=GYDS

# Theme color (hex)
VITE_THEME_COLOR=#0f1318

# Background color for splash screen
VITE_BACKGROUND_COLOR=#0f1318

# ── DEX / Swap ───────────────────────────────
# Swap fee percentage (default 0.3)
VITE_SWAP_FEE=0.3

# Default slippage tolerance percentage (default 1.0)
VITE_DEFAULT_SLIPPAGE=1.0

# ── Web3 Provider ────────────────────────────
# Set to "false" to disable window.ethereum injection
# When enabled, external dApps can detect this wallet
VITE_INJECT_WEB3_PROVIDER=true

# ── Admin ────────────────────────────────────
# Comma-separated list of wallet addresses that have admin access.
# Only these wallets can see and access the /admin panel.
# Admins can add more admin wallets at runtime from the panel.
VITE_ADMIN_WALLETS=0x2c31DaaB3130d37C5b8502Db2b459270AE875303,0xF905FB8ada9FC3ae47BD601fB78d3F0aC2923aa1,0x6422D12BFADdEE5142BFaD21b3006a74D09017B1

# ── Build / Dev ──────────────────────────────
# Dev server port (default 8080)
VITE_PORT=8080
